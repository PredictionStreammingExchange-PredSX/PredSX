# ── DATABASE CONFIG ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=predsx

CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=default

# ── KAFKA CONFIG ──────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── EXTERNAL SERVICES ─────────────────────────────────────────────────────────
# Replace with your actual Alchemy/Polygon RPC URL
POLYGON_RPC_URL=wss://polygon-mainnet.g.alchemy.com/v2/your-api-key

# ── API CONFIG ────────────────────────────────────────────────────────────────
API_PORT=8081
BACKTEST_PORT=8082

# ── SERVICE TUNING ────────────────────────────────────────────────────────────
WS_CONNECTIONS=4
BATCH_SIZE=500
FLUSH_INTERVAL_MS=100
EMA_ALPHA=0.2
IMBALANCE_DEPTH=10
SPREAD_THRESHOLD=0.03
IMBALANCE_THRESHOLD=0.35
LIQUIDITY_GAP_THRESHOLD=0.05
ARBITRAGE_THRESHOLD=0.02
VOLUME_SPIKE_THRESHOLD=5.0
MOMENTUM_THRESHOLD=0.05
HIST_CONTEXT_TTL_SEC=60
